{
   "name": "@ota/storage",
   "private": true,
   "type": "module",
   "exports": {
      ".": {
         "types": "./dist/index.d.ts",
         "default": "./src/index.ts"
      },
      "./client": {
         "types": "./dist/client.d.ts",
         "default": "./src/client.ts"
      }
   },
   "license": "MIT",
   "scripts": {
      "build": "tsc",
      "clean": "git clean -xdf .cache .turbo dist node_modules .local",
      "dev": "garage -c ./.garage/garage.toml server",
      "format": "prettier --check . --ignore-path ../../.gitignore",
      "lint": "eslint .",
      "typecheck": "tsc --noEmit --emitDeclarationOnly false"
   },
   "dependencies": {
      "@aws-sdk/client-s3": "^3.1001.0",
      "@aws-sdk/s3-request-presigner": "^3.1001.0",
      "@ota/env": "workspace:*"
   },
   "devDependencies": {
      "@ota/eslint-config": "workspace:*",
      "@ota/prettier-config": "workspace:*",
      "@ota/tsconfig": "workspace:*",
      "eslint": "catalog:",
      "prettier": "catalog:",
      "typescript": "catalog:"
   },
   "prettier": "@ota/prettier-config"
}
