{
   "name": "@ota/web",
   "private": true,
   "version": "0.0.1",
   "type": "module",
   "scripts": {
      "localize": "bunx --bun @inlang/paraglide-js compile --project ../../packages/i18n/project.inlang --emit-ts-declarations --silent --outdir ./src/lib/paraglide",
      "dev": "vite dev",
      "build": "vite build",
      "preview": "vite preview",
      "prepare": "bun run localize && svelte-kit sync",
      "lint": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && eslint .",
      "format": "prettier --write .",
      "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
   },
   "dependencies": {
      "@orpc/client": "catalog:",
      "@orpc/contract": "catalog:",
      "@orpc/openapi": "^1.13.5",
      "@orpc/server": "catalog:",
      "@ota/api": "workspace:*",
      "@ota/auth": "workspace:*",
      "@ota/db": "workspace:*",
      "@ota/ui": "workspace:*",
      "better-auth": "catalog:",
      "mode-watcher": "^1.1.0"
   },
   "devDependencies": {
      "@hugeicons/core-free-icons": "catalog:",
      "@hugeicons/svelte": "catalog:",
      "@inlang/paraglide-js": "^2.12.0",
      "@ota/eslint-config": "workspace:*",
      "@ota/prettier-config": "workspace:*",
      "@ota/svelte-config": "workspace:*",
      "@ota/tailwind-config": "workspace:*",
      "@ota/tsconfig": "workspace:*",
      "@sveltejs/kit": "catalog:",
      "@sveltejs/vite-plugin-svelte": "catalog:",
      "@types/node": "catalog:",
      "eslint": "catalog:",
      "prettier": "catalog:",
      "svelte": "catalog:",
      "svelte-check": "catalog:",
      "svelte-flag-icons": "^3.0.1",
      "tailwind-variants": "^3.2.2",
      "tailwindcss": "catalog:",
      "tw-animate-css": "catalog:",
      "typescript": "catalog:",
      "vite": "catalog:",
      "wrangler": "4.53.0"
   },
   "prettier": "@ota/prettier-config"
}
