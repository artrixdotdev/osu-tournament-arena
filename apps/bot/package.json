{
   "name": "@ota/bot",
   "private": true,
   "type": "module",
   "license": "MIT",
   "scripts": {
      "build": "tsc",
      "register": "dotenv -c --e ../../.env tsx register.ts",
      "clean": "git clean -xdf .cache .turbo dist node_modules",
      "dev": "dotenv -c --e ../../.env wrangler dev",
      "format": "prettier --check . --ignore-path ../../.gitignore",
      "lint": "eslint",
      "typecheck": "tsc --noEmit --emitDeclarationOnly false"
   },
   "devDependencies": {
      "@ota/discord": "workspace:*",
      "@ota/env": "workspace:*",
      "@ota/eslint-config": "workspace:*",
      "@ota/prettier-config": "workspace:*",
      "@ota/tsconfig": "workspace:*",
      "@types/node": "catalog:",
      "eslint": "catalog:",
      "prettier": "catalog:",
      "tsx": "^4.21.0",
      "typescript": "catalog:",
      "wrangler": "catalog:"
   },
   "prettier": "@ota/prettier-config",
   "dependencies": {
      "discord-api-types": "catalog:",
      "discord-hono": "^0.20.3"
   }
}
